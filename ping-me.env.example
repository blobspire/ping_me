# Configuration for ~/.codex/skills/ping-me/scripts/ping_me.sh
#
# Active laptop suppression for direct/manual script use. The Codex ping-me
# skill calls the script with --force because an explicit "ping me" should
# always notify when the task finishes.
PING_ME_MIN_IDLE_SECONDS=120

# macOS caffeinate arguments used while a ping-me task is running.
# -d prevents display sleep, -i prevents idle system sleep, -m prevents disk
# sleep on macOS versions that support it, and -s prevents system sleep on AC power.
PING_ME_CAFFEINATE_ARGS=-dims

# Choose: auto, pushover, ntfy, imessage, or macos.
# auto uses Pushover if configured, then ntfy, then iMessage, then macOS.
PING_ME_TRANSPORT=ntfy

# ntfy: install the ntfy iOS app, subscribe to the topic URL printed by
# install.sh, and keep the topic name private. Anyone who knows an unauthenticated
# public ntfy.sh topic can publish to it or subscribe to it.
PING_ME_NTFY_TOPIC=replace-with-your-private-random-topic
# PING_ME_NTFY_URL=
# PING_ME_NTFY_TOKEN=
PING_ME_NTFY_PRIORITY=default
PING_ME_NTFY_TAGS=computer

# Pushover: optional alternative to ntfy.
# PING_ME_PUSHOVER_USER_KEY=
# PING_ME_PUSHOVER_API_TOKEN=
# PING_ME_PUSHOVER_PRIORITY=0
# PING_ME_PUSHOVER_SOUND=

# iMessage: optional. This requires Messages automation permission and a target
# Apple ID or phone number that will actually alert your iPhone/watch.
# PING_ME_IMESSAGE_TARGET=
